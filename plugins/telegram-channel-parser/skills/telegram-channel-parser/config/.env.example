# Telegram Channel Parser — optional config
# Copy to .env to override defaults: cp .env.example .env

# Channels for digest (comma-separated, without @)
# If not set, the built-in community list is used
TG_CHANNELS=countwithsasha,evilfreelancer,aostrikov_ai_agents,tips_ai,neuraldeep,oestick,max_about_ai,kdoronin_blog,nobilix,the_ai_architect,dealerAI,gleb_pro_ai,elkornacio,etechlead,NGI_ru

# Cache TTL in hours (default: 6)
TG_CACHE_TTL_HOURS=6
