# Telegram Channel Parser — config
# Copy to .env to enable digests: cp .env.example .env
# Without .env the skill still works — just pass --channels explicitly.

# ─── Digest categories ───────────────────────────────────────
# Define channel lists by category. The agent reads these and
# picks the right one based on your request.
# Format: comma-separated usernames without @

# AI & Tech community digest
TG_CHANNELS=countwithsasha,evilfreelancer,aostrikov_ai_agents,tips_ai,neuraldeep,oestick,max_about_ai,kdoronin_blog,nobilix,the_ai_architect,dealerAI,gleb_pro_ai,elkornacio,etechlead,NGI_ru

# Add your own categories:
# TG_CHANNELS_CRYPTO=channel1,channel2,channel3
# TG_CHANNELS_NEWS=channel1,channel2,channel3
# TG_CHANNELS_DESIGN=channel1,channel2,channel3
